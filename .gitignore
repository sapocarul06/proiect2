```gitignore
# Build artifacts
*.obj
*.exe
*.dll
*.so
*.a
*.lib
*.pdb
*.ilk
*.exp
*.dSYM/
*.dylib

# Dependencies
packages/
bin/
obj/
out/

# Logs
*.log

# Environment
.env
.env.local
*.env.*

# OS generated files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Coverage reports
coverage/
htmlcov/
.coverage

# Distribution / packaging
dist/
build/
*.tar.gz
*.whl
*.egg-info/

# Testing
*.pytest_cache/
.mypy_cache/
```